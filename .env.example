# === MongoDB (production) ===
MONGO_ROOT_USER=asel
MONGO_ROOT_PASSWORD=change-me-in-production
MONGO_DB=asel

# === Server ===
# REQUIRED — generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES=12h
BCRYPT_ROUNDS=12
# Set to "true" behind HTTPS (strongly recommended in prod)
COOKIE_SECURE=false
# Exact origin(s) the browser will use — no wildcards
CORS_ORIGINS=http://localhost:8080

# === First-run admin seed ===
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMeNow!2024

# === Client ===
# Port the nginx-served SPA listens on, locally
CLIENT_PORT=8080
