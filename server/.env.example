NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://asel:asel-dev-password@localhost:27017/asel?authSource=admin

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES=12h
BCRYPT_ROUNDS=12

# Cookies
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS — comma separated origins
CORS_ORIGINS=http://localhost:5173

# Seed (used by `npm run seed`)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMeNow!2024
